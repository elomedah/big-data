<?xml version="1.0"?>
<configuration>
  <property>
    <name>yarn.resourcemanager.hostname</name>
    <value>{{ hostvars[resourcemanager_host].private_ip }}</value>
  </property>
  <property>
    <name>yarn.nodemanager.aux-services</name>
    <value>mapreduce_shuffle</value>
  </property>
  <property>
    <name>yarn.nodemanager.local-dirs</name>
    <value>{{ yarn_local_dir }}</value>
  </property>
  <property>
    <name>yarn.nodemanager.log-dirs</name>
    <value>{{ yarn_log_dir }}</value>
  </property>
  <property>
    <name>yarn.scheduler.capacity.maximum-allocation-mb</name>
    <value>{{ yarn_maximum_allocation_mb }}</value>
  </property>
  <property>
    <name>yarn.scheduler.capacity.maximum-allocation-vcores</name>
    <value>{{ yarn_maximum_allocation_vcores }}</value>
  </property>
  <property>
    <name>yarn.resourcemanager.scheduler.class</name>
    <value>org.apache.hadoop.yarn.server.resourcemanager.scheduler.capacity.CapacityScheduler</value>
  </property>
</configuration>
